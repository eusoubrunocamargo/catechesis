# Template for local dev environment.
# Copy this file to .env.dev at the repo root and adjust as needed.
# .env.dev is gitignored — each machine maintains its own copy.

# --- Database ---
DATABASE_URL=jdbc:postgresql://localhost:5432/catechesis_dev
DATABASE_USER=catechesis_dev
DATABASE_PASSWORD=dev

# --- Application mode ---
SPRING_PROFILES_ACTIVE=dev
APP_AUTH_MODE=dev
